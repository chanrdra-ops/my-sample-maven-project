<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Automation Framework Suite" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="com.automation.core.listeners.TestListener"/>
    </listeners>

    <test name="UI Smoke Tests">
        <groups>
            <run>
                <include name="ui"/>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.automation.tests.ui.SeleniumHomeTest"/>
        </classes>
    </test>

    <test name="API Smoke Tests">
        <groups>
            <run>
                <include name="api"/>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.automation.tests.api.PostsApiTest"/>
        </classes>
    </test>
</suite>
